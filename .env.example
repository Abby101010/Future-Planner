# NorthStar — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Anthropic API Key (required for AI features)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Override the API server port (default: 3741)
# NORTHSTAR_API_PORT=3741

# Edition: set to "personal" to enable personal-only features.
# Leave blank or remove for public/cloud deployment.
# NORTHSTAR_EDITION=personal
