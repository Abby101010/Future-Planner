# Copy to .env and fill in for local dev
# Production uses Fly secrets, not this file

# Postgres connection string (from Supabase → Project Settings → Database → Connection String → URI)
DATABASE_URL=postgres://postgres:password@localhost:5432/starward

# Anthropic API key — server-side only, never exposed to clients
ANTHROPIC_API_KEY=sk-ant-...

# Phase 1: hardcoded single-user mode
# Phase 2: remove this and switch authMiddleware to JWT verification
DEV_USER_ID=sophie

# Server port (Fly sets this automatically in production)
PORT=3741
