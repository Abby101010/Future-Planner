  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
